{
  "model": {
    "default": "gemini-3-pro"
  },
  "hooks": {
    "AfterTool": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$GEMINI_PROJECT_DIR/.gemini/hooks/validate-draft.sh\"",
            "name": "Validate proposal and implementation output",
            "timeout": 60000
          }
        ]
      }
    ]
  }
}
